{
  "name": "forge-manager",
  "version": "1.0.0",
  "description": "3D Printer Task and Filament Manager",
  "main": "index.html",
  "scripts": {
    "start": "npx serve .",
    "cap:init": "npx cap init FORGE_MANAGER com.forge.manager --web-dir .",
    "cap:add:android": "npm install @capacitor/android && npx cap add android",
    "cap:add:ios": "npm install @capacitor/ios && npx cap add ios",
    "cap:sync": "npx cap sync"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  }
}
